# Upstream search service consumed by src/lib/search/search-provider.ts.
# Run `npm run search-service` to start the local seed upstream service on port 8080.
SEARCH_SERVICE_URL=http://localhost:8080/api/search
SEARCH_SERVICE_METHOD=POST
SEARCH_SERVICE_PROVIDER=auto
SEARCH_SERVICE_API_KEY=your-api-key
SEARCH_SERVICE_AUTH_HEADER=Authorization
SEARCH_SERVICE_LIMIT=6
SEARCH_SERVICE_TIMEOUT_MS=8000

# Optional generative answer layer. Defaults to extractive answers and does not
# call an LLM unless SEARCH_ANSWER_MODE is set to llm or auto and a key/model are configured.
SEARCH_ANSWER_MODE=extractive
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=your-chat-model
LLM_TIMEOUT_MS=12000
LLM_TEMPERATURE=0.2

# Postgres database for the ingestion pipeline.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres
SEARCH_DATABASE_SCHEMA=public

# Optional ingestion pipeline overrides.
INGEST_SOURCE_IDS=tjcu-main-notices,tjcu-library,tjcu-academic-affairs,tjcu-undergrad-admissions,tjcu-grad-admissions
INGEST_FETCH_LIMIT=12
INGEST_HTTP_TIMEOUT_MS=15000
INGEST_CONCURRENCY=4
INGEST_USER_AGENT=campus-rag-ingestion/1.0 (+https://www.tjcu.edu.cn/)
