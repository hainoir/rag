# Upstream search service consumed by src/lib/search/search-provider.ts.
# Run `npm run search-service` to start the local seed upstream service on port 8080.
SEARCH_SERVICE_URL=http://localhost:8080/api/search
SEARCH_SERVICE_METHOD=POST
SEARCH_SERVICE_PROVIDER=auto
SEARCH_SERVICE_API_KEY=your-api-key
SEARCH_SERVICE_AUTH_HEADER=Authorization
SEARCH_SERVICE_LIMIT=6
SEARCH_SERVICE_TIMEOUT_MS=8000
SEARCH_ADMIN_TIMEOUT_MS=8000
ADMIN_DASHBOARD_TOKEN=your-admin-dashboard-token

# Optional Redis-backed search gateway hardening. When REDIS_URL is omitted,
# local demo requests bypass cache and rate limiting.
REDIS_URL=redis://127.0.0.1:6379/0
SEARCH_CACHE_TTL_SECONDS=300
SEARCH_CACHE_PREFIX=campus-rag
SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
SEARCH_RATE_LIMIT_MAX=60
INGEST_QUEUE_NAME=campus-rag:ingestion
INGEST_WORKER_IDLE_SLEEP_MS=10000

# Optional generative answer layer. Defaults to extractive answers and does not
# call an LLM unless SEARCH_ANSWER_MODE is set to llm or auto and a key/model are configured.
SEARCH_ANSWER_MODE=extractive
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=your-chat-model
LLM_TIMEOUT_MS=12000
LLM_TEMPERATURE=0.2

# Postgres database for the ingestion pipeline.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres
SEARCH_DATABASE_SCHEMA=public

# Optional ingestion pipeline overrides.
INGEST_SOURCE_IDS=tjcu-main-notices,tjcu-library,tjcu-academic-affairs,tjcu-undergrad-admissions,tjcu-grad-admissions
INGEST_COMMUNITY_SOURCE_IDS=tjcu-tieba
INGEST_FETCH_LIMIT=12
INGEST_HTTP_TIMEOUT_MS=15000
INGEST_CONCURRENCY=4
INGEST_RETRY_ATTEMPTS=2
INGEST_RETRY_DELAY_MS=500
INGEST_USER_AGENT=campus-rag-ingestion/1.0 (+https://www.tjcu.edu.cn/)

# Optional moderation for community ingestion. Defaults off. Use report to log
# flagged content while still storing it; use enforce to skip flagged content.
CONTENT_MODERATION_MODE=off
CONTENT_MODERATION_API_KEY=your-moderation-api-key
CONTENT_MODERATION_BASE_URL=https://api.openai.com/v1
CONTENT_MODERATION_MODEL=omni-moderation-latest
CONTENT_MODERATION_TIMEOUT_MS=8000

# Optional pgvector embedding layer. Without EMBEDDING_API_KEY the CLI keeps a
# dry-run/skip boundary and Postgres search falls back to lexical retrieval.
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CHUNK_LIMIT=200
EMBEDDING_BATCH_SIZE=16

# Optional cross-encoder rerank layer. Defaults off unless all three are set.
RERANK_API_KEY=your-rerank-api-key
RERANK_BASE_URL=https://your-rerank-provider.example.com/v1
RERANK_MODEL=your-rerank-model
RERANK_TOP_K=20
RERANK_TIMEOUT_MS=8000
